# ═══════════════════════════════════════════════════════════════
# SkillConnect AI — Backend Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL Database (Neon) ─────────────────────────────────
# Get from: https://neon.tech → Project → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── Firebase Admin SDK ────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Judge0 API (RapidAPI) ─────────────────────────────────────
# Get from: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-rapidapi-key
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ─── AI Service ────────────────────────────────────────────────
# URL where the Python FastAPI AI service is running
AI_SERVICE_URL=http://localhost:8000

# ─── Gemini API ────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ─── Frontend ──────────────────────────────────────────────────
# URL of the frontend app (for CORS)
CLIENT_URL=http://localhost:5173

# ─── External Storage ──────────────────────────────────────────
# URL base for recording storage (Firebase Storage, S3, etc.)
STORAGE_BASE_URL=https://storage.googleapis.com/your-bucket

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
