# ═══════════════════════════════════════════════════════════════
# SkillConnect AI — AI Service Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────
PORT=8000

# ─── Gemini API ────────────────────────────────────────────────
# Used for report generation and AI-powered recommendations
GEMINI_API_KEY=your-gemini-api-key

# ─── Main Backend ──────────────────────────────────────────────
# URL of the Node.js main backend service
MAIN_BACKEND_URL=http://localhost:5000

# ─── Whisper Model ─────────────────────────────────────────────
# Options: tiny, base, small, medium, large
# Smaller = faster but less accurate
WHISPER_MODEL=base
